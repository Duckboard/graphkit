# Copy this file to .env and fill in your own values.
# Never commit the real .env file -- it's already in .gitignore.

# From your Azure app registration (see README.md "Azure app registration" section)
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=your-client-secret-value

# Used by examples/send_email_draft.py
MAILBOX=someone@yourdomain.com

# Used by examples/create_planner_task.py
PLANNER_GROUP_NAME=Operations
PLANNER_PLAN_NAME=Tasks
PLANNER_BUCKET_NAME=To Do
